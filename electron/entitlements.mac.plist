<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow JIT for V8 engine (Electron/Node.js) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow unsigned executable memory (required for Node.js) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Disable library validation for native modules -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Network: client (outbound) — for localhost server -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Network: server (inbound) — for Express server -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File access: user-selected files -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>

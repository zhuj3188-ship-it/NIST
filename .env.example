# QuantumShield Environment Configuration
# Copy this file to .env and modify as needed

# ─── Server ───────────────────────────────────────────
# Port for the Express server
PORT=3001

# Bind address (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Environment mode: development | production
NODE_ENV=development

# ─── Logging ──────────────────────────────────────────
# Log level: error | warn | info | debug
LOG_LEVEL=info

# ─── Scan Engine ──────────────────────────────────────
# Maximum file size for scanning (in bytes, default: 50MB)
MAX_FILE_SIZE=52428800

# Maximum number of files per scan batch
MAX_BATCH_FILES=500

# Enable incremental scan cache
ENABLE_SCAN_CACHE=true

# ─── CORS ─────────────────────────────────────────────
# Allowed origins for CORS (comma-separated, * for all)
CORS_ORIGINS=*

# ─── Electron ─────────────────────────────────────────
# Set to 'true' when running inside Electron
# (automatically set by Electron main process)
# ELECTRON=true
